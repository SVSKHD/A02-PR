# AUREON v2 — environment configuration
# ----------------------------------------------------------------------
# 1. Copy this file to `.env` (no extension prefix, no .example)
#       cp .env.example .env
# 2. Fill in your real values below
# 3. Set file permissions to owner-read-only:
#       chmod 600 .env          (Linux/Mac)
#       icacls .env /inheritance:r /grant:r %USERNAME%:R   (Windows)
# 4. Verify: python telemetry.py  → 5 messages should arrive in Discord
#
# The bot loads this file automatically at startup. If a variable is also
# set in your OS environment, the OS value wins (safe default).
# ----------------------------------------------------------------------


# ===== DISCORD — sole alert + command channel (v3.1.0) ===============
# Discord (discord.com) is the only alert + command channel.
# Bot token from the Discord Developer Portal (Bot tab). REQUIRED for Discord.
DISCORD_BOT_TOKEN=PASTE_YOUR_DISCORD_BOT_TOKEN_HERE
# Numeric channel ID alerts post to / commands are accepted from (enable Developer
# Mode in Discord, right-click the channel → Copy Channel ID). REQUIRED.
DISCORD_CHANNEL_ID=PASTE_YOUR_CHANNEL_ID_HERE
# OPTIONAL: restrict commands to these user IDs (csv). Empty = any user in channel.
# DISCORD_ALLOWED_USER_IDS=
# OPTIONAL: webhook URL used as a send fallback if the bot REST send fails.
# DISCORD_WEBHOOK_URL=
# Which channels are active (csv). Default discord-only.
# AUREON_ALERT_CHANNELS=discord
# IMPORTANT: for COMMANDS, enable "Message Content Intent" in the Developer Portal
# (Bot → Privileged Gateway Intents) and `pip install discord.py` on the VPS.

# Minimum severity sent to alerts. Values: INFO / SUCCESS / WARN / ERROR / CRITICAL
# INFO     = everything (anchors, fills, closes, EOD, …) — best for first 2 weeks
# SUCCESS  = skip INFO chatter, keep wins + warnings + errors
# WARN     = only show problems and emergencies
AUREON_ALERT_MIN_SEVERITY=INFO


# ===== OPTIONAL — Local logging =======================================

# If set, ALL log messages (including DEBUG that never reaches Discord)
# are also written to this file. Useful for post-mortem debugging.
# Leave commented out to log only to stdout/journal.
# AUREON_LOG_FILE=/var/log/aureon/aureon.log


# ===== OPTIONAL — Working directory ===================================

# Where the watchdog writes heartbeat/status.json/commands.json files.
# Default is ./run relative to the bot's working directory.
# AUREON_RUN_DIR=/home/trader/aureon_v2/run


# ===== OPTIONAL — Override the .env path itself =======================
# If you want this .env file to live somewhere other than the bot's working
# directory, set AUREON_ENV_FILE in your OS environment to that path.
# (Cannot be set inside this file — that's circular.)


# ----------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------
# - MT5 credentials are NOT in this file. The bot connects to the
#   already-running MT5 terminal on this machine (which must be logged
#   into your broker account before starting the bot).
#
# - Never commit this file to git. The .gitignore in this directory
#   already excludes .env, but double-check before pushing.
#
# - To rotate the Discord bot token: regenerate it in the Discord Developer
#   Portal (Bot tab → Reset Token) and update this file.

# --- Auto-deploy (INFRA; default OFF) ---------------------------------------
# When ON, the watchdog polls master every AUTODEPLOY_POLL_MIN minutes; on a new
# commit it pulls + validates (py_compile + import) off-tree, then restarts the
# bot ONLY when the book is flat or at EOD (never mid-trade). Leave OFF during
# manual testing so a merge never surprise-deploys.
# AUTODEPLOY_ENABLED=1
# AUTODEPLOY_POLL_MIN=5
