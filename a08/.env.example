# AUREON A08 (MCX port) — environment configuration
# ----------------------------------------------------------------------
#   cp a08/.env.example .env   &&   chmod 600 .env
# OS env vars override .env values (safe default).
# ----------------------------------------------------------------------

# ===== Telegram (shared channel with the MT5 build) ===================
AUREON_TELEGRAM_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
AUREON_TELEGRAM_CHAT=PASTE_YOUR_CHAT_ID_HERE
AUREON_TELEGRAM_MIN_SEVERITY=INFO

# ===== DhanHQ (LIVE only — leave blank for PAPER/SIM) =================
# Client ID + access token from the Dhan developer console.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ===== External XAUUSD spot feed (for the daily R calc) ===============
# R = MCX_quote / XAUUSD. Any spot source; key only needed in LIVE mode.
XAU_SPOT_PROVIDER=
XAU_SPOT_API_KEY=

# ===== Firebase (EOD daily doc, collection aureon_mcx) ================
# Path to the service-account JSON. EOD-only write + weekly reconcile.
A08_FIREBASE_CRED=

# ===== Operational ====================================================
# AUREON_RUN_DIR=./run
# A08_STATE_FILE=a08_mcx_state.json

# ----------------------------------------------------------------------
# PAPER/SIM FIRST. No real rupee until A08 shows its own multi-week green
# record — the MT5 forward record does NOT transfer across the netting change.
# ----------------------------------------------------------------------
